# Image Text Extractor — Environment Configuration
# Copy this file to .env and fill in values as needed.

# Path to the GGUF model file (optional; defaults to models/Llama-3.2-1B-Instruct-Q4_K_M.gguf)
# MODEL_PATH=models/Llama-3.2-1B-Instruct-Q4_K_M.gguf

# Tesseract executable path (optional; defaults to system PATH lookup)
# TESSERACT_CMD=/usr/bin/tesseract

# SQLite database path (optional; defaults to /tmp/ocr_extractions.sqlite3)
# DATABASE_PATH=/tmp/ocr_extractions.sqlite3

# LLM inference parameters
# LLM_N_CTX=2048
# LLM_N_THREADS=4
# LLM_TEMPERATURE=0.1

# Streamlit server config
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
